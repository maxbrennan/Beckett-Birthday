{
  "name": "clairet-birthday",
  "productName": "Clairet Birthday",
  "version": "2.1.1",
  "main": "electron.js",
  "scripts": {
    "build:server": "elm make src/Server.elm --output=elm-server.js",
    "build:client": "elm make src/Main.elm --output=elm-client.js",
    "stop:server": "pm2 stop birthday-server || true",
    "stop:client": "pm2 stop birthday-client || true",
    "start:server": "npm run build:server && pm2 startOrRestart ecosystem.config.js --only birthday-server",
    "start:client": "npm run build:client && pm2 startOrRestart ecosystem.config.js --only birthday-client",
    "stop": "pm2 stop ecosystem.config.js || true",
    "start": "npm run build:server && npm run build:client && pm2 startOrRestart ecosystem.config.js",
    "dist": "npm run build:client && electron-builder",
    "reset": "npm run stop && node reset.js"
  },
  "build": {
    "files": [
      "birthday-client.js",
      "elm-client.js",
      "electron.js",
      "index.html",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "pm2": "^7.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
