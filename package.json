{
  "name": "beckett-birthday",
  "productName": "Beckett Birthday",
  "version": "2.0.2",
  "main": "electron.js",
  "scripts": {
    "build:server": "elm make src/Server.elm --output=elm-server.js",
    "build:client": "elm make src/Main.elm --output=elm-client.js",
    "start:server": "npm run build:server && node server.js",
    "start:client": "npm run build:client && electron .",
    "start": "npm run start:server & npm run start:client",
    "dist": "npm run build:client && electron-builder",
    "reset": "node reset.js"
  },
  "build": {
    "files": [
      "renderer.js",
      "elm-client.js",
      "electron.js",
      "index.html",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
