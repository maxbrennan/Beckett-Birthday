{
  "name": "birthday-present",
  "productName": "Ryan Birthday",
  "version": "3.0.0",
  "main": "electron.js",
  "scripts": {
    "test": "npm run test:elm && npm run test:js && npm run test:gui",
    "test:elm": "npx elm-coverage",
    "test:js": "npx jest --coverage",
    "test:gui": "node tests/gui.electron.js",
    "build:server": "npx elm make src/Server.elm --output=elm-server.js",
    "build:client": "npx elm make src/Main.elm --output=elm-client.js",
    "build": "npm run build:server && npm run build:client",
    "stop:server": "npx pm2 stop birthday-server || true",
    "stop:client": "npx pm2 stop birthday-client || true",
    "stop": "npx pm2 stop ecosystem.config.js || true",
    "start:server": "npm run build:server && npx pm2 startOrRestart ecosystem.config.js --only birthday-server --update-env",
    "start:server:dev": "npm run build:server && npx pm2 startOrRestart ecosystem.config.js --only birthday-server --env dev --update-env",
    "start:client": "npm run build:client && npx pm2 startOrRestart ecosystem.config.js --only birthday-client --update-env",
    "start:client:dev": "npm run build:client && npx pm2 startOrRestart ecosystem.config.js --only birthday-client --env dev --update-env",
    "start": "npm run build && npx pm2 startOrRestart ecosystem.config.js --update-env",
    "start:dev": "npm run build && npx pm2 startOrRestart ecosystem.config.js --env dev --update-env",
    "dist:win": "npm run build:client && npx electron-builder --win",
    "dist:mac": "npm run build:client && npx electron-builder --mac",
    "dist:linux": "npm run build:client && npx electron-builder --linux",
    "deploy:mac": "npm run build:client && node scripts/deploy.js mac",
    "deploy:win": "npm run build:client && node scripts/deploy.js win",
    "deploy:linux": "npm run build:client && node scripts/deploy.js linux",
    "undeploy": "node scripts/undeploy.js",
    "edit:state": "node scripts/edit-state.js",
    "add-admin": "node scripts/add-admin.js"
  },
  "build": {
    "files": [
      ".env",
      "client/bridge.js",
      "elm-client.js",
      "electron.js",
      "index.html",
      "server/codec.js",
      "proto/**/*",
      "assets/**/*",
      "app-uuid.json",
      "quiz-questions.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "elm-test": "^0.19.1-revision17",
    "protobufjs": "^8.6.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.5.2",
    "electron-builder": "^26.15.3",
    "elm-coverage": "^0.4.1",
    "jest": "^29.0.0",
    "playwright": "^1.61.1",
    "pm2": "^6.0.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxbrennan/Beckett-Birthday.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/maxbrennan/Beckett-Birthday/issues"
  },
  "homepage": "https://github.com/maxbrennan/Beckett-Birthday#readme",
  "description": "",
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "fsevents@2.3.3": true
  },
  "type": "commonjs"
}
