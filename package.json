{
  "name": "beckett-birthday",
  "version": "1.0.0",
  "main": "electron.js",
  "scripts": {
    "build:c": "cc src/list_audio_devices.c -framework CoreAudio -framework Foundation -o src/list_audio_devices",
    "build:elm": "elm make src/Main.elm --output=elm.js",
    "build": "npm run build:c && npm run build:elm",
    "start": "npm run build && electron --trace-warnings .",
    "dist": "npm run build && electron-builder",
    "reset": "node reset.js"
  },
  "build": {
    "files": [
      "renderer.js",
      "elm.js",
      "src/list_audio_devices",
      "electron.js",
      "index.html",
      "assets/**/*"
    ],
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "ws": "^8.20.0"
  }
}
